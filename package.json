{
  "name": "qwenasr-tauri",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm i18n:compile && tsc && vite build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --strict",
    "prepare": "husky",
    "preview": "vite preview",
    "test:prepare-mlx": "node --test scripts/prepare-mlx-metallib.test.mjs",
    "tauri:prepare-mlx": "node scripts/prepare-mlx-metallib.mjs",
    "tauri": "PATH=$HOME/.cargo/bin:$PATH tauri",
    "tauri:dev": "PATH=$HOME/.cargo/bin:$PATH tauri dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@ibm/plex-sans-jp": "^3.0.0",
    "@ibm/plex-sans-sc": "^1.1.0",
    "@ibm/plex-sans-tc": "^1.1.1",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^6.5.0",
    "@lingui/cli": "^6.5.0",
    "@lingui/vite-plugin": "^6.5.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "lint-staged": {
    "*.{css,html,js,json,md,mjs,ts,tsx,yaml,yml}": "prettier --write"
  }
}
